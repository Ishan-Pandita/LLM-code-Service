# LLM Service Configuration (vLLM Backend)
# Copy this file to .env and customize as needed

# Model Configuration
LLM_SERVICE_MODEL_ID=zai-org/GLM-4.7-Flash
LLM_SERVICE_MODEL_REVISION=main

# vLLM Engine Configuration
# Number of GPUs for tensor parallelism (set to your GPU count)
LLM_SERVICE_TENSOR_PARALLEL_SIZE=1

# Fraction of GPU memory to use (0.90 = 90%, leave headroom for KV cache)
LLM_SERVICE_GPU_MEMORY_UTILIZATION=0.90

# Maximum sequence length (context window). Reduce if you run out of memory
LLM_SERVICE_MAX_MODEL_LEN=32768

# Data type: 'auto', 'float16', 'bfloat16', 'float32'
LLM_SERVICE_VLLM_DTYPE=auto

# Quantization method (optional, requires quantized model):
# - null/unset: No quantization (default)
# - 'awq': AWQ quantization
# - 'gptq': GPTQ quantization
# - 'fp8': FP8 quantization (requires Hopper GPU)
LLM_SERVICE_QUANTIZATION=

# Enable prefix caching (recommended for repeated system prompts)
LLM_SERVICE_ENABLE_PREFIX_CACHING=true

# Disable CUDA graphs (set to true for debugging or if you encounter issues)
LLM_SERVICE_ENFORCE_EAGER=false

# Generation Defaults (Deterministic by default)
LLM_SERVICE_DEFAULT_MAX_NEW_TOKENS=2048
# Set to 0.0 for deterministic output (greedy decoding)
LLM_SERVICE_DEFAULT_TEMPERATURE=0.0
# Set to 1.0 for deterministic output
LLM_SERVICE_DEFAULT_TOP_P=1.0
# Set to -1 to disable for deterministic output
LLM_SERVICE_DEFAULT_TOP_K=-1
# Set to 1.0 to disable penalty for strict correctness
LLM_SERVICE_DEFAULT_REPETITION_PENALTY=1.0

# Cache Directory (optional, uses HF default if not set)
LLM_SERVICE_CACHE_DIR=

# API Configuration
LLM_SERVICE_API_HOST=0.0.0.0
LLM_SERVICE_API_PORT=8000
LLM_SERVICE_API_WORKERS=1
LLM_SERVICE_COMPILER_BASE_URL=http://localhost:32358

# Logging
LLM_SERVICE_LOG_LEVEL=INFO

# Request Limits
LLM_SERVICE_REQUEST_TIMEOUT=300.0
